{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/swiftlint-autofix.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-done.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "RevenueCat@RevenueCat": true
  },
  "extraKnownMarketplaces": {
    "RevenueCat": {
      "source": {
        "source": "github",
        "repo": "RevenueCat/ai-toolkit"
      }
    }
  },
  "skillOverrides": {
    "alarmkit": "name-only",
    "app-store-submission": "name-only",
    "avfoundation-audio": "name-only",
    "avkit-videoplayer": "name-only",
    "backgroundtasks": "name-only",
    "carplay": "name-only",
    "compact-summary": "name-only",
    "contacts": "name-only",
    "context7-docs-writer": "name-only",
    "core-motion": "name-only",
    "core-nfc": "name-only",
    "corebluetooth": "name-only",
    "corehaptics": "name-only",
    "corelocation": "name-only",
    "coreml": "name-only",
    "corespotlight": "name-only",
    "declared-age-range": "name-only",
    "energykit": "name-only",
    "eventkit": "name-only",
    "firebase": "name-only",
    "gamesave": "name-only",
    "healthkit": "name-only",
    "identity-document-services": "name-only",
    "ios-agents": "name-only",
    "ios-audit": "name-only",
    "ios-automate": "name-only",
    "ios-brief": "name-only",
    "ios-build": "name-only",
    "ios-commit": "name-only",
    "ios-design-audit": "name-only",
    "ios-design-brief": "name-only",
    "ios-design-elevate": "name-only",
    "ios-init": "name-only",
    "ios-load": "name-only",
    "ios-onboarding-advisor": "name-only",
    "ios-onboarding-audit": "name-only",
    "ios-release-notes": "name-only",
    "ios-review": "name-only",
    "ios-test": "name-only",
    "ios-ui-design-advisor": "name-only",
    "ios-ux-advisor": "name-only",
    "keyboard-accessory": "name-only",
    "mapkit": "name-only",
    "messageui": "name-only",
    "oslog-logging": "name-only",
    "pencilkit": "name-only",
    "photosui": "name-only",
    "pr-to-develop": "name-only",
    "pr-to-main": "name-only",
    "privacy-manifest": "name-only",
    "realmswift": "name-only",
    "relevancekit": "name-only",
    "revenuecat": "name-only",
    "safariservices": "name-only",
    "speech-analyzer": "name-only",
    "swift-charts": "name-only",
    "swift-concurrency": "name-only",
    "swift-testing": "name-only",
    "swiftdata": "name-only",
    "swiftui-badge": "name-only",
    "swiftui-expert-skill": "name-only",
    "swiftui-pro": "name-only",
    "swiftui-tabview": "name-only",
    "swiftui-toolbar": "name-only",
    "swiftui-webview": "name-only",
    "tipkit": "name-only",
    "translation": "name-only",
    "universal-links": "name-only",
    "usernotifications": "name-only",
    "watchconnectivity": "name-only",
    "widgetkit": "name-only",
    "wifiaware": "name-only"
  },
  "alwaysThinkingEnabled": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
